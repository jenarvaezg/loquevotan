{
  "name": "loquevotan",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "cf:dev": "npx wrangler dev",
    "cf:prepare-assets": "node scripts/cloudflare/split_large_assets.mjs",
    "cf:d1:seed": "node scripts/cloudflare/build_d1_seed.mjs",
    "cf:deploy": "npm run build && npm run cf:prepare-assets && npx wrangler deploy",
    "qa:refresh-ai-cli": "python3 scripts/qa/refresh_ai_cache_cli.py",
    "qa:madrid": "node scripts/qa/report_madrid_quality.mjs",
    "qa:data-audit": "node scripts/qa/audit_data_quality.mjs",
    "qa:quality-status": "node scripts/qa/build_quality_status.mjs",
    "qa:quality-gate:cyl": "node scripts/qa/check_quality_gate.mjs --scope cyl",
    "test:data-integrity": "node scripts/qa/check_data_integrity.mjs",
    "test:data-artifacts": "node scripts/qa/check_data_artifacts.mjs",
    "test:data": "npm run test:data-integrity && npm run test:data-artifacts",
    "test:unit": "vitest run",
    "test": "npm run test:unit && npm run test:data && npx playwright test"
  },
  "dependencies": {
    "html2canvas": "^1.4.1",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.2",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vue/test-utils": "^2.4.6",
    "jpeg-js": "^0.4.4",
    "jsdom": "^28.1.0",
    "vite": "^6.2.0",
    "vitest": "^4.0.18"
  }
}
